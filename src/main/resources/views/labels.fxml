<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="15" styleClass="module-view" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gestionmorgue.controller.LabelController">
    <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

    <Text styleClass="content-title" text="Étiquettes d'identification" />

    <VBox spacing="10" styleClass="stat-card">
        <Label style="font-size:14pt;font-weight:bold" text="Étiquettes pour emplacements de stockage" />
        <Label text="Génère un document HTML formaté pour impression sur étiquettes 90x55mm." wrapText="true" />
        <Label text="Chaque étiquette affiche le code emplacement, la zone, la température et le défunt assigné." wrapText="true" />
        <Button onAction="#handleGenerateLabels" styleClass="btn-primary" text="Générer les étiquettes" />
    </VBox>
</VBox>
