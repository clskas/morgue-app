<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="15" styleClass="module-view" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gestionmorgue.controller.UserController">
    <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

    <Text styleClass="content-title" text="Gestion des Utilisateurs" />

    <Label styleClass="section-title" text="Fiche utilisateur" />
    <GridPane hgap="10" vgap="10">
        <padding><Insets bottom="10" left="10" right="10" top="10" /></padding>

        <Label text="Nom d'utilisateur *" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="usernameField" promptText="Nom d'utilisateur" GridPane.columnIndex="1" GridPane.rowIndex="0" />
        <Label text="Mot de passe" GridPane.columnIndex="2" GridPane.rowIndex="0" />
        <PasswordField fx:id="passwordField" promptText="Mot de passe" GridPane.columnIndex="3" GridPane.rowIndex="0" />

        <Label text="Nom complet *" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <TextField fx:id="fullNameField" promptText="Nom complet" GridPane.columnIndex="1" GridPane.rowIndex="1" />
        <Label text="Email" GridPane.columnIndex="2" GridPane.rowIndex="1" />
        <TextField fx:id="emailField" promptText="Email" GridPane.columnIndex="3" GridPane.rowIndex="1" />

        <Label text="Rôle *" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <ComboBox fx:id="roleCombo" promptText="Rôle" GridPane.columnIndex="1" GridPane.rowIndex="2" />
        <CheckBox fx:id="activeCheck" selected="true" text="Actif" GridPane.columnIndex="2" GridPane.rowIndex="2" />

        <HBox spacing="10" GridPane.columnIndex="0" GridPane.columnSpan="4" GridPane.rowIndex="3">
            <Button fx:id="saveButton" onAction="#handleSave" styleClass="btn-primary" text="Créer" />
            <Button fx:id="updateButton" onAction="#handleUpdate" text="Modifier" />
            <Button fx:id="resetPasswordButton" onAction="#handleResetPassword" text="Reset mot de passe" />
            <Button fx:id="deleteButton" onAction="#handleDelete" styleClass="btn-danger" text="Supprimer" />
        </HBox>
    </GridPane>

    <Label styleClass="section-title" text="Utilisateurs" />
    <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colUsername" text="Utilisateur" />
            <TableColumn fx:id="colFullName" text="Nom complet" />
            <TableColumn fx:id="colRole" text="Rôle" />
            <TableColumn fx:id="colEmail" text="Email" />
            <TableColumn fx:id="colActive" text="Actif" />
        </columns>
    </TableView>
</VBox>
