<FindBugsFilter>
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2" />
    </Match>
    <Match>
        <Or>
            <Package name="~com\.gestionmorgue\.model\..*" />
            <Package name="~com\.gestionmorgue\.config\..*" />
        </Or>
    </Match>
    <Match>
        <Class name="com.gestionmorgue.service.BackupService" />
        <Bug pattern="SQL_NONCONSTANT_STRING_PASSED_TO_EXECUTE" />
    </Match>
</FindBugsFilter>
